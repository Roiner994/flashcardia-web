---
const { t, lang } = Astro.props;
import '../styles/global.css'
---

<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{t.meta.title}</title>
  <meta name="description" content="{t.meta.description}" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  
  <!-- Ionicons -->
  <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
  <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>

  <!-- Prevent FOUC for dark mode -->
  <script is:inline>
    if (localStorage.getItem('theme') === 'dark' ||
      (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  </script>
</head>

<body class="bg-background-light dark:bg-background-dark text-gray-900 dark:text-gray-100 antialiased selection:bg-primary selection:text-white transition-colors duration-300">

  <!-- ════════════════════ NAV ════════════════════ -->
  <nav class="fixed w-full z-50 glass dark:border-b dark:border-slate-700/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <!-- Logo -->
        <div class="flex-shrink-0 flex items-center gap-2 cursor-pointer">
          <img src="/logo.png" alt="Flashcardia Logo" class="w-10 h-10 rounded-xl shadow-sm" />
          <span class="font-bold text-xl tracking-tight">Flashcardia</span>
        </div>

        <!-- Desktop links -->
        <div class="hidden md:flex space-x-8 text-sm font-medium text-gray-600 dark:text-gray-300">
          <a class="hover:text-primary transition-colors" href="#intelligent-generation">{t.nav.generation}</a>
          <a class="hover:text-primary transition-colors" href="#challenge-mode">{t.nav.challenge}</a>
          <a class="hover:text-primary transition-colors" href="#smart-system">{t.nav.system}</a>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-4">
          <a href="#" onclick="downloadAPK(); return false;" class="bg-primary hover:bg-violet-700 text-white px-5 py-2.5 rounded-full font-medium transition-all shadow-lg shadow-violet-500/30 text-sm hidden sm:block hover-glow">
            {t.nav.download}
          </a>
          
          <!-- Language Selector -->
          <div class="flex bg-gray-100 dark:bg-gray-800 rounded-full p-1 text-xs font-bold shadow-sm border border-gray-200/50 dark:border-gray-700/50">
            <a href="/" class={`px-3 py-1.5 rounded-full transition-colors duration-200 ${lang === 'en' ? 'bg-white dark:bg-gray-600 text-primary dark:text-white shadow-sm' : 'text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-200'}`}>
              {t.nav.language_en}
            </a>
            <a href="/es" class={`px-3 py-1.5 rounded-full transition-colors duration-200 ${lang === 'es' ? 'bg-white dark:bg-gray-600 text-primary dark:text-white shadow-sm' : 'text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-200'}`}>
              {t.nav.language_es}
            </a>
          </div>

          <!-- Theme Toggle -->
          <div id="theme-toggle" class="relative flex items-center bg-gray-100 dark:bg-gray-800 rounded-full p-1 cursor-pointer transition-colors duration-300">
            <!-- Sliding highlight pill -->
            <div id="theme-pill" class="absolute top-1 h-[calc(100%-8px)] w-[calc(50%-2px)] bg-white dark:bg-gray-600 rounded-full shadow-sm transition-all duration-300 ease-in-out left-1 dark:left-[calc(50%+1px)]"></div>
            <!-- Light mode icon (active in light) -->
            <span class="relative z-10 material-symbols-outlined p-1.5 text-[20px] rounded-full transition-colors duration-300 text-amber-500 dark:text-gray-500">light_mode</span>
            <!-- Dark mode icon (active in dark) -->
            <span class="relative z-10 material-symbols-outlined p-1.5 text-[20px] rounded-full transition-colors duration-300 text-gray-400 dark:text-violet-300">dark_mode</span>
          </div>
          
          
        </div>
      </div>
    </div>
  </nav>

  <!-- ════════════════════ HERO ════════════════════ -->
  <section class="pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden relative">
    <!-- Decorative blobs -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl -z-10 pointer-events-none">
      <div class="absolute top-20 left-10 w-72 h-72 bg-purple-300 dark:bg-purple-900 rounded-full mix-blend-multiply dark:mix-blend-color filter blur-3xl opacity-30"></div>
      <div class="absolute top-20 right-10 w-72 h-72 bg-blue-300 dark:bg-blue-900 rounded-full mix-blend-multiply dark:mix-blend-color filter blur-3xl opacity-30"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">

        <!-- Copy -->
        <div class="flex-1 text-center lg:text-left">
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 leading-tight">
            {t.hero.title1} <br /><span class="gradient-text">{t.hero.title2}</span>
          </h1>

          <p class="text-lg lg:text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
            {t.hero.subtitle}
          </p>
        </div>

        <!-- Phone mockup -->
        <div class="flex-1 relative w-full flex justify-center lg:justify-end">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-to-tr from-violet-100 to-blue-50 dark:from-violet-900/20 dark:to-blue-900/20 rounded-full blur-3xl -z-10"></div>
          <div class="flex flex-col items-center">
            <div class="relative w-[300px] h-[600px] bg-gray-900 dark:bg-black rounded-[3rem] border-[8px] border-gray-900 dark:border-gray-950 shadow-2xl overflow-hidden ring-1 ring-white/10">
              <div class="w-full h-full bg-[#F3F0FF] dark:bg-[#0f172a] relative overflow-hidden">
              <!-- Screen Carousel Container -->
              <div class="phone-carousel w-full h-full relative">

                <!-- SCREEN 1: Home / Decks -->
                <div class="phone-screen absolute inset-0 flex flex-col p-5 pt-8">
                  <!-- Header -->
                  <div class="flex justify-between items-center mb-5">
                    <h2 class="text-xl font-extrabold"><span class="text-primary">Flashcard</span><span class="text-cyan-500">ia</span></h2>
                    <div class="flex items-center gap-2">
                      <div class="w-8 h-8 rounded-full bg-gray-300 dark:bg-gray-700 overflow-hidden">
                        <img alt="avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDeYjKi3L6pgwLOf5QkDwrfToeoYrKKR5xkbpuRALFk8ifHO_d7aiRc5pWt5RHvLZzK9Cx-i88ap-5VU0Okae7ldt8GCSTsjxaaaagEzUucOkgsihv2JyREMVAapQfe8kRT3f9P3OpXz-PXfUmFkyyVDoTak7luCMQQDmOiVbLcjzDNl9IMBz1NabQ6i8NWbX0f3DbapzNOibSqlL3iKhty2uo6ZVKzNijw-0aawlKd9FdGWpNWX3U0x_Q7_9Z6DmfzdO1ENYZ8a2I" class="w-full h-full object-cover" />
                      </div>
                      <div class="flex items-center gap-1 bg-orange-100 dark:bg-orange-900/40 px-2 py-1 rounded-full">
                        <ion-icon name="flame" class="text-orange-500 text-[10px]"></ion-icon>
                        <span class="text-orange-600 dark:text-orange-400 text-[10px] font-bold">1</span>
                      </div>
                    </div>
                  </div>
                  <!-- Stats -->
                  <div class="grid grid-cols-2 gap-3 mb-5">
                    <div class="bg-white dark:bg-slate-800 rounded-xl p-3 shadow-sm dark:shadow-none dark:border dark:border-slate-700/50">
                      <div class="flex items-center gap-1 mb-1"><ion-icon name="alarm-outline" class="text-orange-400 text-[10px]"></ion-icon><span class="text-[9px] text-gray-500 dark:text-gray-400">{t.phone_home.due_today}</span></div>
                      <p class="text-lg font-extrabold text-gray-900 dark:text-white">{t.phone_home.cards_5}</p>
                    </div>
                    <div class="bg-white dark:bg-slate-800 rounded-xl p-3 shadow-sm dark:shadow-none dark:border dark:border-slate-700/50">
                      <div class="flex items-center gap-1 mb-1"><ion-icon name="trending-up-outline" class="text-green-500 text-[10px]"></ion-icon><span class="text-[9px] text-gray-500 dark:text-gray-400">{t.phone_home.learned}</span></div>
                      <p class="font-extrabold text-gray-900 dark:text-white">{t.phone_home.words_4}</p>
                    </div>
                  </div>
                  <!-- Deck list -->
                  <p class="text-sm font-bold text-gray-900 dark:text-white mb-3">{t.phone_home.your_decks}</p>
                  <div class="flex flex-col gap-2.5">
                    <div class="bg-white dark:bg-slate-800 rounded-xl p-3 flex items-center justify-between shadow-sm dark:shadow-none dark:border dark:border-slate-700/50">
                      <div class="flex items-center gap-2.5">
                        <div class="w-9 h-9 rounded-lg bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center text-primary text-xs font-bold">文A</div>
                        <div><p class="text-sm font-bold text-gray-900 dark:text-white">{t.phone_home.phrases}</p><p class="text-[9px] text-gray-400">{t.phone_home.cards_2}</p></div>
                      </div>
                      <div class="flex gap-1.5"><span class="bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">2</span><span class="bg-red-100 dark:bg-red-900/40 text-red-500 dark:text-red-400 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span><span class="bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span></div>
                    </div>
                    <div class="bg-white dark:bg-slate-800 rounded-xl p-3 flex items-center justify-between shadow-sm dark:shadow-none dark:border dark:border-slate-700/50">
                      <div class="flex items-center gap-2.5">
                        <div class="w-9 h-9 rounded-lg bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center text-primary text-xs font-bold">文A</div>
                        <div><p class="text-sm font-bold text-gray-900 dark:text-white">{t.phone_home.verbs}</p><p class="text-[9px] text-gray-400">{t.phone_home.cards_3}</p></div>
                      </div>
                      <div class="flex gap-1.5"><span class="bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">3</span><span class="bg-red-100 dark:bg-red-900/40 text-red-500 dark:text-red-400 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span><span class="bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span></div>
                    </div>
                    <div class="bg-white dark:bg-slate-800 rounded-xl p-3 flex items-center justify-between shadow-sm dark:shadow-none dark:border dark:border-slate-700/50">
                      <div class="flex items-center gap-2.5">
                        <div class="w-9 h-9 rounded-lg bg-purple-100 dark:bg-purple-900/40 flex items-center justify-center text-primary text-xs font-bold">文A</div>
                        <div><p class="text-sm font-bold text-gray-900 dark:text-white">{t.phone_home.b2_words}</p><p class="text-[9px] text-gray-400">{t.phone_home.cards_4}</p></div>
                      </div>
                      <div class="flex gap-1.5"><span class="bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span><span class="bg-red-100 dark:bg-red-900/40 text-red-500 dark:text-red-400 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span><span class="bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span></div>
                    </div>
                  </div>
                  <!-- FAB & Tab Bar -->
                  <div class="mt-auto pt-3 flex justify-end"><div class="w-12 h-12 rounded-full bg-primary shadow-lg flex items-center justify-center text-white text-2xl font-light"><ion-icon name="add-outline"></ion-icon></div></div>
                  <div class="flex justify-around pt-3 border-t border-gray-200 dark:border-slate-700 mt-3">
                    <div class="flex flex-col items-center"><ion-icon name="albums" class="text-primary text-[18px]"></ion-icon><span class="text-[8px] font-bold text-primary mt-0.5">{t.phone_home.decks}</span></div>
                    <div class="flex flex-col items-center"><ion-icon name="trophy-outline" class="text-gray-400 dark:text-slate-500 text-[18px]"></ion-icon><span class="text-[8px] text-gray-400 dark:text-slate-500 mt-0.5">{t.nav.challenge}</span></div>
                    <div class="flex flex-col items-center"><ion-icon name="settings-outline" class="text-gray-400 dark:text-slate-500 text-[18px]"></ion-icon><span class="text-[8px] text-gray-400 dark:text-slate-500 mt-0.5">{t.phone_home.settings}</span></div>
                  </div>
                </div>

                <!-- SCREEN 2: Card Review (Reliable) -->
                <div class="phone-screen absolute inset-0 flex flex-col p-5 pt-8 opacity-0">
                  <!-- Header -->
                  <div class="flex justify-between items-center mb-4">
                    <ion-icon name="close" class="text-gray-600 dark:text-gray-400 text-xl"></ion-icon>
                    <div class="flex gap-2"><span class="text-blue-500 font-bold text-sm">3</span><span class="text-red-500 font-bold text-sm">0</span><span class="text-green-500 font-bold text-sm">0</span></div>
                    <ion-icon name="options-outline" class="text-gray-500 dark:text-gray-400 text-lg"></ion-icon>
                  </div>
                  <!-- Main Card -->
                  <div class="flex-1 flex flex-col items-center justify-center bg-white dark:bg-slate-800 rounded-3xl shadow-sm dark:shadow-none dark:border dark:border-slate-700/50 p-6 my-2">
                    <span class="bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400 text-[9px] font-bold px-3 py-1 rounded-full uppercase mb-3">{t.phone_review.definition}</span>
                    <p class="text-center text-base font-bold text-gray-900 dark:text-white leading-snug mb-4">{t.phone_review.reliable_def}</p>
                    <span class="bg-purple-100 dark:bg-purple-900/40 text-primary text-[9px] font-bold px-3 py-1 rounded-full uppercase mb-2 flex items-center justify-center gap-1"><ion-icon name="eye-outline" class="text-[10px]"></ion-icon> {t.phone_review.meaning}</span>
                    <p class="text-gray-500 dark:text-gray-400 text-xs mb-4 flex items-center justify-center gap-1"><ion-icon name="volume-medium-outline" class="text-sm"></ion-icon> //rɪˈlaɪəbəl//</p>
                    <div class="w-8 border-t border-gray-200 dark:border-slate-700 mb-4"></div>
                    <div class="space-y-2 text-center">
                      <p class="text-[11px] text-gray-400 dark:text-gray-500 italic">{t.phone_review.reliable_ex1}</p>
                      <p class="text-[11px] text-gray-400 dark:text-gray-500 italic">{t.phone_review.reliable_ex2}</p>
                    </div>
                  </div>
                  <!-- Spaced Repetition Buttons -->
                  <div class="grid grid-cols-4 gap-2 mt-3">
                    <div class="flex flex-col items-center p-2 rounded-xl bg-white dark:bg-slate-800 border border-red-100 dark:border-red-900/50"><span class="text-[10px] font-bold text-red-500 dark:text-red-400 uppercase">{t.phone_review.again}</span><span class="text-[9px] text-gray-400 dark:text-gray-500">1m</span></div>
                    <div class="flex flex-col items-center p-2 rounded-xl bg-white dark:bg-slate-800 border border-yellow-100 dark:border-yellow-900/50"><span class="text-[10px] font-bold text-yellow-500 dark:text-yellow-400 uppercase">{t.phone_review.hard}</span><span class="text-[9px] text-gray-400 dark:text-gray-500">10m</span></div>
                    <div class="flex flex-col items-center p-2 rounded-xl bg-white dark:bg-slate-800 border border-green-100 dark:border-green-900/50"><span class="text-[10px] font-bold text-green-500 dark:text-green-400 uppercase">{t.phone_review.good}</span><span class="text-[9px] text-gray-400 dark:text-gray-500">1d</span></div>
                    <div class="flex flex-col items-center p-2 rounded-xl bg-white dark:bg-slate-800 border border-blue-100 dark:border-blue-900/50"><span class="text-[10px] font-bold text-blue-500 dark:text-blue-400 uppercase">{t.phone_review.easy}</span><span class="text-[9px] text-gray-400 dark:text-gray-500">4d</span></div>
                  </div>
                </div>

                <!-- SCREEN 3: Challenge Setup -->
                <div class="phone-screen absolute inset-0 flex flex-col p-5 pt-7 opacity-0">
                  <!-- Header -->
                  <div class="flex items-center mb-4 mt-1">
                    <ion-icon name="close" class="text-[#8b5cf6] font-bold text-xl absolute"></ion-icon>
                    <h2 class="w-full text-center text-[14px] font-extrabold text-[#111827] dark:text-white">{t.phone_setup.challenge_setup}</h2>
                  </div>
                  
                  <div class="border-b-[1px] border-[#f3f4f6] dark:border-slate-700 -mx-5 mb-4 mt-[-12px]"></div>

                  <!-- Title -->
                  <h1 class="text-[20px] font-extrabold text-[#111827] dark:text-white mb-0.5">{t.phone_home.verbs}</h1>
                  <p class="text-[11px] text-[#6b7280] dark:text-gray-400 mb-4 font-medium"><strong class="text-[#111827] dark:text-white">3</strong> {t.phone_setup.cards_available_3}</p>
                  
                  <!-- Card type pills -->
                  <div class="flex gap-2 mb-4">
                    <!-- New -->
                    <div class="flex-1 flex flex-col items-center bg-[#f0f5ff] dark:bg-blue-900/30 border border-[#60a5fa] dark:border-blue-500/50 rounded-xl py-2 px-1 relative shadow-sm dark:shadow-none">
                      <div class="w-6 h-6 rounded-full bg-[#dbeafe] dark:bg-blue-900/50 flex items-center justify-center mb-1"><ion-icon name="sparkles" class="text-[#3b82f6] text-[13px]"></ion-icon></div>
                      <span class="text-[10px] font-bold text-[#3b82f6]">{t.phone_setup.new}</span>
                      <span class="absolute top-1.5 right-1.5 w-1 h-1 bg-[#3b82f6] rounded-full"></span>
                    </div>
                    <!-- Active -->
                    <div class="flex-1 flex flex-col items-center bg-[#fff1f2] dark:bg-red-900/30 border border-[#f87171] dark:border-red-500/50 rounded-xl py-2 px-1 relative shadow-sm dark:shadow-none">
                      <div class="w-6 h-6 rounded-full bg-[#ffe4e6] dark:bg-red-900/50 flex items-center justify-center mb-1"><ion-icon name="school" class="text-[#ef4444] text-[13px]"></ion-icon></div>
                      <span class="text-[10px] font-bold text-[#ef4444]">{t.phone_setup.active}</span>
                      <span class="absolute top-1.5 right-1.5 w-1 h-1 bg-[#ef4444] rounded-full"></span>
                    </div>
                    <!-- Review -->
                    <div class="flex-1 flex flex-col items-center bg-[#f0fdf4] dark:bg-emerald-900/30 border border-[#10b981] dark:border-emerald-500/50 rounded-xl py-2 px-1 relative shadow-sm dark:shadow-none">
                      <div class="w-6 h-6 rounded-full bg-[#dcfce7] dark:bg-emerald-900/50 flex items-center justify-center mb-1"><ion-icon name="checkmark-circle" class="text-[#10b981] text-[13px]"></ion-icon></div>
                      <span class="text-[10px] font-bold text-[#10b981]">{t.phone_setup.review}</span>
                      <span class="absolute top-1.5 right-1.5 w-1 h-1 bg-[#10b981] rounded-full"></span>
                    </div>
                  </div>
                  
                  <!-- Number of Cards -->
                  <h3 class="text-[14px] font-bold text-[#111827] dark:text-white mb-2.5">{t.phone_setup.number_of_cards}</h3>
                  <div class="flex gap-2 mb-5">
                    <span class="bg-[#8b5cf6] text-white text-[12px] font-extrabold flex-1 h-[38px] rounded-xl flex items-center justify-center shadow-md">10</span>
                    <span class="bg-white dark:bg-slate-800 text-[#111827] dark:text-white text-[12px] font-extrabold flex-1 h-[38px] rounded-xl flex items-center justify-center border border-[#f3f4f6] dark:border-slate-700">20</span>
                    <span class="bg-white dark:bg-slate-800 text-[#111827] dark:text-white text-[12px] font-extrabold flex-1 h-[38px] rounded-xl flex items-center justify-center border border-[#f3f4f6] dark:border-slate-700">50</span>
                    <span class="bg-white dark:bg-slate-800 text-[#111827] dark:text-white text-[12px] font-extrabold flex-1 h-[38px] rounded-xl flex items-center justify-center border border-[#f3f4f6] dark:border-slate-700">{t.phone_setup.all}</span>
                    <span class="bg-white dark:bg-slate-800 text-[#111827] dark:text-white text-[16px] flex-1 h-[38px] rounded-xl flex items-center justify-center border border-[#f3f4f6] dark:border-slate-700"><ion-icon name="pencil"></ion-icon></span>
                  </div>
                  
                  <!-- Difficulty Mode -->
                  <h3 class="text-[14px] font-bold text-[#111827] dark:text-white mb-2.5">{t.phone_setup.difficulty_mode}</h3>
                  <div class="grid grid-cols-2 gap-3 mb-4">
                    <!-- Easy -->
                    <div class="border-[1.5px] border-[#f59e0b] rounded-[16px] pb-3 pt-4 flex flex-col items-center relative bg-[#fffbeb] dark:bg-amber-900/20 shadow-sm dark:shadow-none">
                      <span class="absolute -top-1 -right-1 w-4.5 h-4.5 bg-[#f59e0b] rounded-full flex items-center justify-center text-white pb-[1px] text-[11px] border-2 border-white dark:border-slate-900"><ion-icon name="checkmark-outline" class="stroke-2"></ion-icon></span>
                      <ion-icon name="bicycle-outline" class="text-[#f59e0b] text-[30px] mb-1.5 stroke-1"></ion-icon>
                      <span class="text-[13px] font-bold text-[#f59e0b]">{t.phone_review.easy}</span>
                    </div>
                    <!-- Hard -->
                    <div class="border border-[#f3f4f6] dark:border-slate-700 rounded-[16px] pb-3 pt-4 flex flex-col items-center bg-white dark:bg-slate-800 shadow-sm dark:shadow-none">
                      <ion-icon name="flame" class="text-[#111827] dark:text-white text-[30px] mb-1.5"></ion-icon>
                      <span class="text-[13px] font-bold text-[#111827] dark:text-white">{t.phone_review.hard}</span>
                    </div>
                  </div>

                  <!-- Info alert -->
                  <div class="bg-[#fffbeb] dark:bg-amber-900/20 border border-[#fef3c7] dark:border-amber-700/40 rounded-[12px] p-2.5 flex items-start gap-2 mb-3 mt-auto">
