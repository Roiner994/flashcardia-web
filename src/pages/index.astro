---
import '../styles/global.css'
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Flashcardia — Expand Your Vocabulary. Never Forget a Word.</title>
  <meta name="description" content="The intelligent flashcard ecosystem for capturing, retaining, and mastering knowledge. Convert short-term memory into long-term mastery." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  
  <!-- Ionicons -->
  <script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
  <script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>

  <!-- Prevent FOUC for dark mode -->
  <script is:inline>
    if (localStorage.getItem('theme') === 'dark' ||
      (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  </script>
</head>

<body class="bg-background-light dark:bg-background-dark text-gray-900 dark:text-gray-100 antialiased selection:bg-primary selection:text-white transition-colors duration-300">

  <!-- ════════════════════ NAV ════════════════════ -->
  <nav class="fixed w-full z-50 glass dark:border-b dark:border-slate-700/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <!-- Logo -->
        <div class="flex-shrink-0 flex items-center gap-2 cursor-pointer">
          <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white">
            <span class="material-symbols-outlined text-xl">style</span>
          </div>
          <span class="font-bold text-xl tracking-tight">Flashcardia</span>
        </div>

        <!-- Desktop links -->
        <div class="hidden md:flex space-x-8 text-sm font-medium text-gray-600 dark:text-gray-300">
          <a class="hover:text-primary transition-colors" href="#intelligent-generation">Generation</a>
          <a class="hover:text-primary transition-colors" href="#challenge-mode">Challenge</a>
          <a class="hover:text-primary transition-colors" href="#smart-system">System</a>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-4">
          <button id="theme-toggle" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-500 dark:text-gray-400">
            <span class="material-symbols-outlined dark:hidden">dark_mode</span>
            <span class="material-symbols-outlined hidden dark:block">light_mode</span>
          </button>
          <button class="bg-primary hover:bg-violet-700 text-white px-5 py-2.5 rounded-full font-medium transition-all shadow-lg shadow-violet-500/30 text-sm hidden sm:block hover-glow">
            Download Now
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- ════════════════════ HERO ════════════════════ -->
  <section class="pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden relative">
    <!-- Decorative blobs -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl -z-10 pointer-events-none">
      <div class="absolute top-20 left-10 w-72 h-72 bg-purple-300 dark:bg-purple-900 rounded-full mix-blend-multiply dark:mix-blend-color filter blur-3xl opacity-30"></div>
      <div class="absolute top-20 right-10 w-72 h-72 bg-blue-300 dark:bg-blue-900 rounded-full mix-blend-multiply dark:mix-blend-color filter blur-3xl opacity-30"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">

        <!-- Copy -->
        <div class="flex-1 text-center lg:text-left">
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 leading-tight">
            Expand Your Vocabulary. <br /><span class="gradient-text">Never Forget a Word.</span>
          </h1>

          <p class="text-lg lg:text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
            The AI-powered ecosystem for capturing, retaining, and mastering knowledge. Convert short-term memory into long-term mastery.
          </p>
        </div>

        <!-- Phone mockup -->
        <div class="flex-1 relative w-full flex justify-center lg:justify-end">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-gradient-to-tr from-violet-100 to-blue-50 dark:from-violet-900/20 dark:to-blue-900/20 rounded-full blur-3xl -z-10"></div>
          <div class="flex flex-col items-center">
            <div class="relative w-[300px] h-[600px] bg-gray-900 rounded-[3rem] border-[8px] border-gray-900 shadow-2xl overflow-hidden ring-1 ring-white/10">
              <div class="w-full h-full bg-[#F3F0FF] relative overflow-hidden">
              <!-- Screen Carousel Container -->
              <div class="phone-carousel w-full h-full relative">

                <!-- SCREEN 1: Home / Decks -->
                <div class="phone-screen absolute inset-0 flex flex-col p-5 pt-8">
                  <!-- Header -->
                  <div class="flex justify-between items-center mb-5">
                    <h2 class="text-xl font-extrabold"><span class="text-primary">Flashcard</span><span class="text-cyan-500">ia</span></h2>
                    <div class="flex items-center gap-2">
                      <div class="w-8 h-8 rounded-full bg-gray-300 overflow-hidden">
                        <img alt="avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDeYjKi3L6pgwLOf5QkDwrfToeoYrKKR5xkbpuRALFk8ifHO_d7aiRc5pWt5RHvLZzK9Cx-i88ap-5VU0Okae7ldt8GCSTsjxaaaagEzUucOkgsihv2JyREMVAapQfe8kRT3f9P3OpXz-PXfUmFkyyVDoTak7luCMQQDmOiVbLcjzDNl9IMBz1NabQ6i8NWbX0f3DbapzNOibSqlL3iKhty2uo6ZVKzNijw-0aawlKd9FdGWpNWX3U0x_Q7_9Z6DmfzdO1ENYZ8a2I" class="w-full h-full object-cover" />
                      </div>
                      <div class="flex items-center gap-1 bg-orange-100 px-2 py-1 rounded-full">
                        <ion-icon name="flame" class="text-orange-500 text-[10px]"></ion-icon>
                        <span class="text-orange-600 text-[10px] font-bold">1</span>
                      </div>
                    </div>
                  </div>
                  <!-- Stats -->
                  <div class="grid grid-cols-2 gap-3 mb-5">
                    <div class="bg-white rounded-xl p-3 shadow-sm">
                      <div class="flex items-center gap-1 mb-1"><ion-icon name="alarm-outline" class="text-orange-400 text-[10px]"></ion-icon><span class="text-[9px] text-gray-500">Due Today</span></div>
                      <p class="text-lg font-extrabold text-gray-900">5 Cards</p>
                    </div>
                    <div class="bg-white rounded-xl p-3 shadow-sm">
                      <div class="flex items-center gap-1 mb-1"><ion-icon name="trending-up-outline" class="text-green-500 text-[10px]"></ion-icon><span class="text-[9px] text-gray-500">Learned</span></div>
                      <p class="text-lg font-extrabold text-gray-900">4 Words</p>
                    </div>
                  </div>
                  <!-- Deck list -->
                  <p class="text-sm font-bold text-gray-900 mb-3">Your Decks</p>
                  <div class="flex flex-col gap-2.5">
                    <div class="bg-white rounded-xl p-3 flex items-center justify-between shadow-sm">
                      <div class="flex items-center gap-2.5">
                        <div class="w-9 h-9 rounded-lg bg-purple-100 flex items-center justify-center text-primary text-xs font-bold">文A</div>
                        <div><p class="text-sm font-bold text-gray-900">Phrases</p><p class="text-[9px] text-gray-400">2 cards</p></div>
                      </div>
                      <div class="flex gap-1.5"><span class="bg-green-100 text-green-600 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">2</span><span class="bg-red-100 text-red-500 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span><span class="bg-green-100 text-green-600 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span></div>
                    </div>
                    <div class="bg-white rounded-xl p-3 flex items-center justify-between shadow-sm">
                      <div class="flex items-center gap-2.5">
                        <div class="w-9 h-9 rounded-lg bg-purple-100 flex items-center justify-center text-primary text-xs font-bold">文A</div>
                        <div><p class="text-sm font-bold text-gray-900">Verbs</p><p class="text-[9px] text-gray-400">3 cards</p></div>
                      </div>
                      <div class="flex gap-1.5"><span class="bg-green-100 text-green-600 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">3</span><span class="bg-red-100 text-red-500 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span><span class="bg-green-100 text-green-600 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span></div>
                    </div>
                    <div class="bg-white rounded-xl p-3 flex items-center justify-between shadow-sm">
                      <div class="flex items-center gap-2.5">
                        <div class="w-9 h-9 rounded-lg bg-purple-100 flex items-center justify-center text-primary text-xs font-bold">文A</div>
                        <div><p class="text-sm font-bold text-gray-900">B2 words</p><p class="text-[9px] text-gray-400">4 cards</p></div>
                      </div>
                      <div class="flex gap-1.5"><span class="bg-green-100 text-green-600 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span><span class="bg-red-100 text-red-500 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span><span class="bg-green-100 text-green-600 text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span></div>
                    </div>
                  </div>
                  <!-- FAB & Tab Bar -->
                  <div class="mt-auto pt-3 flex justify-end"><div class="w-12 h-12 rounded-full bg-primary shadow-lg flex items-center justify-center text-white text-2xl font-light"><ion-icon name="add-outline"></ion-icon></div></div>
                  <div class="flex justify-around pt-3 border-t border-gray-200 mt-3">
                    <div class="flex flex-col items-center"><ion-icon name="albums" class="text-primary text-[18px]"></ion-icon><span class="text-[8px] font-bold text-primary mt-0.5">Decks</span></div>
                    <div class="flex flex-col items-center"><ion-icon name="trophy-outline" class="text-gray-400 text-[18px]"></ion-icon><span class="text-[8px] text-gray-400 mt-0.5">Challenge</span></div>
                    <div class="flex flex-col items-center"><ion-icon name="settings-outline" class="text-gray-400 text-[18px]"></ion-icon><span class="text-[8px] text-gray-400 mt-0.5">Settings</span></div>
                  </div>
                </div>

                <!-- SCREEN 2: Card Review (Reliable) -->
                <div class="phone-screen absolute inset-0 flex flex-col p-5 pt-8 opacity-0">
                  <!-- Header -->
                  <div class="flex justify-between items-center mb-4">
                    <ion-icon name="close" class="text-gray-600 text-xl"></ion-icon>
                    <div class="flex gap-2"><span class="text-blue-500 font-bold text-sm">3</span><span class="text-red-500 font-bold text-sm">0</span><span class="text-green-500 font-bold text-sm">0</span></div>
                    <ion-icon name="options-outline" class="text-gray-500 text-lg"></ion-icon>
                  </div>
                  <!-- Main Card -->
                  <div class="flex-1 flex flex-col items-center justify-center bg-white rounded-3xl shadow-sm p-6 my-2">
                    <span class="bg-green-100 text-green-600 text-[9px] font-bold px-3 py-1 rounded-full uppercase mb-3">Definition</span>
                    <p class="text-center text-base font-bold text-gray-900 leading-snug mb-4">Consistently good in quality or performance; able to be trusted</p>
                    <span class="bg-purple-100 text-primary text-[9px] font-bold px-3 py-1 rounded-full uppercase mb-2 flex items-center justify-center gap-1"><ion-icon name="eye-outline" class="text-[10px]"></ion-icon> Meaning</span>
                    <p class="text-gray-500 text-xs mb-4 flex items-center justify-center gap-1"><ion-icon name="volume-medium-outline" class="text-sm"></ion-icon> //rɪˈlaɪəbəl//</p>
                    <div class="w-8 border-t border-gray-200 mb-4"></div>
                    <div class="space-y-2 text-center">
                      <p class="text-[11px] text-gray-400 italic">"She's a reliable friend, always there to help"</p>
                      <p class="text-[11px] text-gray-400 italic">"The company is reliable and delivers high-quality products"</p>
                    </div>
                  </div>
                  <!-- Spaced Repetition Buttons -->
                  <div class="grid grid-cols-4 gap-2 mt-3">
                    <div class="flex flex-col items-center p-2 rounded-xl bg-white border border-red-100"><span class="text-[10px] font-bold text-red-500 uppercase">Again</span><span class="text-[9px] text-gray-400">1m</span></div>
                    <div class="flex flex-col items-center p-2 rounded-xl bg-white border border-yellow-100"><span class="text-[10px] font-bold text-yellow-500 uppercase">Hard</span><span class="text-[9px] text-gray-400">10m</span></div>
                    <div class="flex flex-col items-center p-2 rounded-xl bg-white border border-green-100"><span class="text-[10px] font-bold text-green-500 uppercase">Good</span><span class="text-[9px] text-gray-400">1d</span></div>
                    <div class="flex flex-col items-center p-2 rounded-xl bg-white border border-blue-100"><span class="text-[10px] font-bold text-blue-500 uppercase">Easy</span><span class="text-[9px] text-gray-400">4d</span></div>
                  </div>
                </div>

                <!-- SCREEN 3: Challenge Setup -->
                <div class="phone-screen absolute inset-0 flex flex-col p-5 pt-7 opacity-0">
                  <!-- Header -->
                  <div class="flex items-center mb-4 mt-1">
                    <ion-icon name="close" class="text-[#8b5cf6] font-bold text-xl absolute"></ion-icon>
                    <h2 class="w-full text-center text-[14px] font-extrabold text-[#111827]">Challenge Setup</h2>
                  </div>
                  
                  <div class="border-b-[1px] border-[#f3f4f6] -mx-5 mb-4 mt-[-12px]"></div>

                  <!-- Title -->
                  <h1 class="text-[20px] font-extrabold text-[#111827] mb-0.5">Verbs</h1>
                  <p class="text-[11px] text-[#6b7280] mb-4 font-medium"><strong class="text-[#111827]">3</strong> cards available</p>
                  
                  <!-- Card type pills -->
                  <div class="flex gap-2 mb-4">
                    <!-- New -->
                    <div class="flex-1 flex flex-col items-center bg-[#f0f5ff] border border-[#60a5fa] rounded-xl py-2 px-1 relative shadow-sm">
                      <div class="w-6 h-6 rounded-full bg-[#dbeafe] flex items-center justify-center mb-1"><ion-icon name="sparkles" class="text-[#3b82f6] text-[13px]"></ion-icon></div>
                      <span class="text-[10px] font-bold text-[#3b82f6]">New</span>
                      <span class="absolute top-1.5 right-1.5 w-1 h-1 bg-[#3b82f6] rounded-full"></span>
                    </div>
                    <!-- Active -->
                    <div class="flex-1 flex flex-col items-center bg-[#fff1f2] border border-[#f87171] rounded-xl py-2 px-1 relative shadow-sm">
                      <div class="w-6 h-6 rounded-full bg-[#ffe4e6] flex items-center justify-center mb-1"><ion-icon name="school" class="text-[#ef4444] text-[13px]"></ion-icon></div>
                      <span class="text-[10px] font-bold text-[#ef4444]">Active</span>
                      <span class="absolute top-1.5 right-1.5 w-1 h-1 bg-[#ef4444] rounded-full"></span>
                    </div>
                    <!-- Review -->
                    <div class="flex-1 flex flex-col items-center bg-[#f0fdf4] border border-[#10b981] rounded-xl py-2 px-1 relative shadow-sm">
                      <div class="w-6 h-6 rounded-full bg-[#dcfce7] flex items-center justify-center mb-1"><ion-icon name="checkmark-circle" class="text-[#10b981] text-[13px]"></ion-icon></div>
                      <span class="text-[10px] font-bold text-[#10b981]">Review</span>
                      <span class="absolute top-1.5 right-1.5 w-1 h-1 bg-[#10b981] rounded-full"></span>
                    </div>
                  </div>
                  
                  <!-- Number of Cards -->
                  <h3 class="text-[14px] font-bold text-[#111827] mb-2.5">Number of Cards</h3>
                  <div class="flex gap-2 mb-5">
                    <span class="bg-[#8b5cf6] text-white text-[12px] font-extrabold flex-1 h-[38px] rounded-xl flex items-center justify-center shadow-md">10</span>
                    <span class="bg-white text-[#111827] text-[12px] font-extrabold flex-1 h-[38px] rounded-xl flex items-center justify-center border border-[#f3f4f6]">20</span>
                    <span class="bg-white text-[#111827] text-[12px] font-extrabold flex-1 h-[38px] rounded-xl flex items-center justify-center border border-[#f3f4f6]">50</span>
                    <span class="bg-white text-[#111827] text-[12px] font-extrabold flex-1 h-[38px] rounded-xl flex items-center justify-center border border-[#f3f4f6]">All</span>
                    <span class="bg-white text-[#111827] text-[16px] flex-1 h-[38px] rounded-xl flex items-center justify-center border border-[#f3f4f6]"><ion-icon name="pencil"></ion-icon></span>
                  </div>
                  
                  <!-- Difficulty Mode -->
                  <h3 class="text-[14px] font-bold text-[#111827] mb-2.5">Difficulty Mode</h3>
                  <div class="grid grid-cols-2 gap-3 mb-4">
                    <!-- Easy -->
                    <div class="border-[1.5px] border-[#f59e0b] rounded-[16px] pb-3 pt-4 flex flex-col items-center relative bg-[#fffbeb] shadow-sm">
                      <span class="absolute -top-1 -right-1 w-4.5 h-4.5 bg-[#f59e0b] rounded-full flex items-center justify-center text-white pb-[1px] text-[11px] border-2 border-white"><ion-icon name="checkmark-outline" class="stroke-2"></ion-icon></span>
                      <ion-icon name="bicycle-outline" class="text-[#f59e0b] text-[30px] mb-1.5 stroke-1"></ion-icon>
                      <span class="text-[13px] font-bold text-[#f59e0b]">Easy</span>
                    </div>
                    <!-- Hard -->
                    <div class="border border-[#f3f4f6] rounded-[16px] pb-3 pt-4 flex flex-col items-center bg-white shadow-sm">
                      <ion-icon name="flame" class="text-[#111827] text-[30px] mb-1.5"></ion-icon>
                      <span class="text-[13px] font-bold text-[#111827]">Hard</span>
                    </div>
                  </div>

                  <!-- Info alert -->
                  <div class="bg-[#fffbeb] border border-[#fef3c7] rounded-[12px] p-2.5 flex items-start gap-2 mb-3 mt-auto">
                    <ion-icon name="information-circle" class="text-[#f59e0b] text-[17px] mt-[1px] flex-shrink-0"></ion-icon>
                    <p class="text-[11px] font-bold text-[#f59e0b] leading-[1.3]">Just finish all cards. No score requirements.<br/>Great for practice.</p>
                  </div>
                  
                  <!-- CTA -->
                  <div class="mb-1">
                    <button class="w-full bg-[#8b5cf6] text-white font-bold py-3 rounded-xl text-[14px] flex items-center justify-center gap-2 shadow-[0_4px_12px_0_rgba(139,92,246,0.3)]">
                      Start Challenge <ion-icon name="arrow-forward" class="text-[13px] stroke-2"></ion-icon>
                    </button>
                  </div>
                </div>

                <!-- SCREEN 4: Challenge Result (Score) -->
                <div class="phone-screen absolute inset-0 flex flex-col p-5 pt-8 opacity-0">
                  <!-- Progress bar -->
                  <div class="flex items-center gap-2 mb-3">
                    <ion-icon name="close" class="text-gray-600 text-xl"></ion-icon>
                    <div class="flex-1 h-1.5 bg-gray-200 rounded-full overflow-hidden"><div class="w-1/3 h-full bg-primary rounded-full"></div></div>
                    <span class="text-[10px] text-gray-500 font-bold">1/3</span>
                  </div>
                  <p class="text-center text-xs text-gray-500 mb-1">Make a sentence with:</p>
                  <h3 class="text-center text-2xl font-extrabold text-gray-900 mb-1">Create</h3>
                  <p class="text-center text-[10px] text-gray-400 italic mb-4">to make or bring into existence something new</p>
                  <!-- Input -->
                  <div class="bg-white rounded-2xl p-4 mb-4 shadow-sm border border-gray-100 min-h-[60px]">
                    <p class="text-sm text-gray-800">I create a word</p>
                  </div>
                  <!-- Score Card -->
                  <div class="bg-white border-2 border-green-400 rounded-2xl p-4 shadow-sm mb-4">
                    <div class="flex items-center justify-between mb-2">
                      <div class="flex items-center gap-1.5 text-green-500 font-bold text-base"><ion-icon name="checkmark-circle" class="text-green-500 text-xl"></ion-icon> Score: 6</div>
                      <ion-icon name="bulb-outline" class="text-yellow-400 text-xl"></ion-icon>
                    </div>
                    <p class="text-[11px] text-gray-600 leading-relaxed mb-3">The word 'create' is used in the sentence, but it's not entirely clear what you mean by 'create a word'. The phrase could be improved for better clarity and specificity.</p>
                    <div class="bg-purple-50 border border-purple-100 rounded-xl p-2.5">
                      <p class="text-[9px] font-bold text-primary uppercase mb-1 flex items-center gap-1"><ion-icon name="sparkles" class="text-primary text-[10px]"></ion-icon> Better way to say it</p>
                      <p class="text-[11px] text-gray-800 italic">I am going to create a new word for our game.</p>
                    </div>
                  </div>
                  <!-- CTA -->
                  <div class="mt-auto">
                    <button class="w-full bg-secondary text-white font-bold py-3 rounded-2xl text-sm flex items-center justify-center gap-2">Next Card <ion-icon name="arrow-forward-outline" class="text-lg"></ion-icon></button>
                  </div>
                </div>

              </div>
            </div>
            </div>
            
            <!-- Screen Captions -->
            <div class="mt-8 text-center h-16 w-full relative flex justify-center items-center">
              <div class="phone-caption absolute opacity-100 translate-y-0 transition-all duration-700 ease-out flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-violet-100 dark:bg-violet-900/50 flex items-center justify-center"><ion-icon name="albums" class="text-violet-600 dark:text-violet-400 text-lg"></ion-icon></div>
                <span class="font-extrabold text-gray-800 dark:text-gray-100 text-[14px] tracking-tight">Manage your decks</span>
              </div>
              <div class="phone-caption absolute opacity-0 translate-y-4 transition-all duration-700 ease-out flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/50 flex items-center justify-center"><ion-icon name="repeat" class="text-blue-600 dark:text-blue-400 text-lg"></ion-icon></div>
                <span class="font-extrabold text-gray-800 dark:text-gray-100 text-[14px] tracking-tight">Study with spaced repetition</span>
              </div>
              <div class="phone-caption absolute opacity-0 translate-y-4 transition-all duration-700 ease-out flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-orange-100 dark:bg-orange-900/50 flex items-center justify-center"><ion-icon name="trophy" class="text-orange-600 dark:text-orange-400 text-lg"></ion-icon></div>
                <span class="font-extrabold text-gray-800 dark:text-gray-100 text-[14px] tracking-tight">Challenge yourself</span>
              </div>
              <div class="phone-caption absolute opacity-0 translate-y-4 transition-all duration-700 ease-out flex items-center gap-3">
