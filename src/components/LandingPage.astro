  <!-- ════════════════════ CLIENT SCRIPT ════════════════════ -->
  <script is:inline>
    document.getElementById('theme-toggle').addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    // Phone screen carousel
    (function () {
      const screens = document.querySelectorAll('.phone-screen');
      const captions = document.querySelectorAll('.phone-caption');
      if (!screens.length) return;
      let current = 0;
      screens[0].classList.add('active');

      setInterval(() => {
        screens[current].classList.remove('active');
        if (captions.length) {
          captions[current].classList.replace('opacity-100', 'opacity-0');
          captions[current].classList.replace('translate-y-0', 'translate-y-4');
        }
        
        current = (current + 1) % screens.length;
        
        screens[current].classList.add('active');
        if (captions.length) {
          captions[current].classList.replace('opacity-0', 'opacity-100');
          captions[current].classList.replace('translate-y-4', 'translate-y-0');
        }
      }, 5000);
    })();

    // APK download handler
    function downloadAPK() {
      window.open('https://drive.google.com/file/d/1rEW0IhN7-r2OmlXdGj0p86sfUKFQ688D/view?usp=sharing', '_blank');
    }
  </script>
